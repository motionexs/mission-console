generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data/performance-brain.db"
}

/// Tracks vault notes (concepts, sources, workflows, field insights)
model VaultNote {
  id        String   @id @default(cuid())
  title     String
  type      String   // "concept" | "source" | "workflow" | "field-insight"
  folder    String   // e.g. "Sports Science", "Recovery"
  status    String   @default("developing") // developing | updated | archived
  confidence String  @default("medium") // high | medium | low
  lines     Int      @default(0)
  words     Int      @default(0)
  links     String   @default("[]") // JSON array of linked note titles
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([folder])
}

/// Installed Hermes skills
model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  category    String?
  isActive    Boolean  @default(true)
  lastUsed    DateTime?
  createdAt   DateTime @default(now())

  @@index([category])
}

/// Hermes conversation sessions
model Session {
  id        String   @id @default(cuid())
  title     String?
  source    String   @default("cli") // cli | telegram | discord | web
  messages  Int      @default(0)
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Scheduled cron jobs
model CronJob {
  id        String   @id @default(cuid())
  name      String
  schedule  String   // "30m", "0 9 * * *", etc.
  prompt    String
  isActive  Boolean  @default(true)
  lastRun   DateTime?
  runCount  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([isActive])
}

/// Research articles / sources tracked in vault
model Article {
  id          String   @id @default(cuid())
  title       String
  authors     String?
  journal     String?
  year        Int?
  pmid        String?  @unique
  doi         String?  @unique
  url         String?
  abstract    String?
  keyFindings String?  // JSON
  linkedNotes String   @default("[]") // JSON array of VaultNote IDs
  createdAt   DateTime @default(now())

  @@index([year])
}

/// System health / status log
model HealthLog {
  id           String   @id @default(cuid())
  vaultSize    Int      @default(0)
  noteCount    Int      @default(0)
  skillCount   Int      @default(0)
  sessionCount Int      @default(0)
  timestamp    DateTime @default(now())
}
